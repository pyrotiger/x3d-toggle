#!/bin/bash

TARGET=$(ls /sys/devices/platform/AMDI*/amd_x3d_mode 2>/dev/null | head -n 1)

if [ -z "$TARGET" ] || [ ! -f "$TARGET" ]; then
    kdialog --error "AMD X3D vCache interface not found. Check UEFI/Kernel settings or insert an actual X3D CPU with vCache technology ."
    exit 1
fi

CURRENT_MODE=$(cat "$TARGET" | tr -d '[:space:]')

# UI Selection
RAW_CHOICE=$(kdialog --title "AMD X3D VCACHE Control" --radiolist "Current Status: <font color='#ff6d00'><b>${CURRENT_MODE^^}</b></font> mode <br><br><br><br> Select priority CCD:<br>" \
    "cache" "Rabbit Mode (Gaming/Low Latency - CCD0)" $([[ "$CURRENT_MODE" == "cache" ]] && echo "on" || echo "off") \
    "frequency" "Cheetah Mode (LLM/Raw Compute - CCD1)" $([[ "$CURRENT_MODE" == "frequency" ]] && echo "on" || echo "off") \
    "auto" "Whose turn is it, anyway? (Auto)" $([[ "$CURRENT_MODE" == "auto" ]] && echo "on" || echo "off"))

[ -z "$RAW_CHOICE" ] && exit 0

# Sanitization
case "$RAW_CHOICE" in
    "cache"|"frequency"|"auto")
        MODE="$RAW_CHOICE"
        ;;
    *)
        kdialog --error "Invalid mode: $RAW_CHOICE"
        exit 1
        ;;
esac

# Execute Hardware Write
if pkexec sh -c "echo $MODE > $TARGET"; then
    ICON_PATH="/usr/share/x3d-toggle/ryzen.jpeg"

    if [ -f "$ICON_PATH" ]; then
        DISPLAY_ICON="file://$ICON_PATH"
    else
        DISPLAY_ICON="cpu"
    fi

    notify-send -i "$DISPLAY_ICON" "AMD X3D VCACHE: ${MODE^^}" "Mode Engaged."
else
    kdialog --error "Hardware write failed. Check permissions or kernel support for '${MODE}'."
fi
