#!/usr/bin/env bash
#X3D-Toggle v1.2.0 - Autonomous Daemon Scheduler
#Copyright (C) 2026 Pyrotiger

STEAM_DATA="$HOME/.local/share/Steam/steamapps"

if ! x3d-toggle get &>/dev/null; then
    echo "Error: AMD X3D hardware interface not found. Exiting daemon." >&2
    echo "Check UEFI settings and kernel support for AMD X3D vCache." >&2
    exit 1
fi

CONFIG_FILE="${X3D_CONFIG_FILE:-/etc/x3d-toggle.conf}"
POLL_INTERVAL=3
COMPUTE_LOAD_THRESHOLD=50
GAME_DETECTION_MODE=2

load_config() {
    [ -f "$CONFIG_FILE" ] || return 0

    while IFS= read -r line || [ -n "$line" ]; do
        line="${line%%#*}"
        line="${line%%$'\r'}"
        [[ -z "${line//[[:space:]]/}" ]] && continue

        if [[ "$line" =~ ^[[:space:]]*POLL_INTERVAL[[:space:]]*=[[:space:]]*([0-9]+)[[:space:]]*$ ]]; then
            POLL_INTERVAL="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^[[:space:]]*COMPUTE_LOAD_THRESHOLD[[:space:]]*=[[:space:]]*([0-9]+)[[:space:]]*$ ]]; then
            COMPUTE_LOAD_THRESHOLD="${BASH_REMATCH[1]}"
        elif [[ "$line" =~ ^[[:space:]]*GAME_DETECTION_MODE[[:space:]]*=[[:space:]]*([0-9]+)[[:space:]]*$ ]]; then
            GAME_DETECTION_MODE="${BASH_REMATCH[1]}"
        fi
    done < "$CONFIG_FILE"
}

load_config

if ! [[ $POLL_INTERVAL =~ ^[0-9]+$ ]] || [ "$POLL_INTERVAL" -lt 1 ]; then
    echo "Warning: Invalid POLL_INTERVAL value. Resetting to default (3s)." >&2
    POLL_INTERVAL=3
fi

if ! [[ $COMPUTE_LOAD_THRESHOLD =~ ^[0-9]+$ ]] || [ "$COMPUTE_LOAD_THRESHOLD" -lt 10 ] || [ "$COMPUTE_LOAD_THRESHOLD" -gt 90 ]; then
    echo "Warning: Invalid COMPUTE_LOAD_THRESHOLD value. Resetting to default (50)." >&2
    COMPUTE_LOAD_THRESHOLD=50
fi

if ! [[ $GAME_DETECTION_MODE =~ ^[0-9]+$ ]] || { [ "$GAME_DETECTION_MODE" -ne 1 ] && [ "$GAME_DETECTION_MODE" -ne 2 ]; }; then
    echo "Warning: Invalid GAME_DETECTION_MODE value. Resetting to default (2)." >&2
    GAME_DETECTION_MODE=2
fi

GAME_EXECS=""
CACHE_INTERVAL=60
CACHE_COUNTER=0

refresh_game_cache() {
    if [[ "${GAME_DETECTION_MODE:-2}" == "2" ]]; then
        GAME_EXECS="|"$(find /usr/share/applications -name "*.desktop" -print0 2>/dev/null | xargs -0 grep -l "Categories=.*Game" 2>/dev/null | xargs -d '\n' grep -h "^Exec=" 2>/dev/null | sed 's/^Exec=\([^ ]*\).*$/\1/' | xargs -n 1 basename 2>/dev/null | sort -u | tr '\n' '|')
    fi
}

refresh_game_cache

check_gaming_intent() {
    if command -v gamemoded &> /dev/null && gamemoded -s 2>/dev/null | grep -qw "active"; then
        return 0
    fi

    if [ -d "$STEAM_DATA" ]; then
        if pgrep -f "steam-runtime|Proton|wine-preloader|steamapps\/common" > /dev/null 2>&1; then
            return 0
        fi
    fi
    
    if [[ "${GAME_DETECTION_MODE:-2}" == "2" ]]; then
        TOP_PROC=$(ps -eo comm --sort=-%cpu 2>/dev/null | head -n 2 | tail -n 1)
        if [[ -n "$TOP_PROC" && "$GAME_EXECS" == *"|$TOP_PROC|"* ]]; then
             return 0
        fi
    fi
    return 1
}

check_compute_intent() {
    local threshold="${COMPUTE_LOAD_THRESHOLD:-50}"
    
    if x3d-toggle check-load "$threshold"; then
        return 0
    fi
    return 1
}

LAST_ERROR_TIME=0
ERROR_COOLDOWN=60

while true; do
    (( CACHE_COUNTER++ ))
    if [ $CACHE_COUNTER -ge $CACHE_INTERVAL ]; then
        refresh_game_cache
        CACHE_COUNTER=0
    fi

    if check_gaming_intent; then
        NEW_MODE="cache"
    elif check_compute_intent; then
        NEW_MODE="frequency"
    else
        NEW_MODE="frequency"
    fi

    CURRENT=$(x3d-toggle get 2>/dev/null)
    if [[ "$CURRENT" != "$NEW_MODE" ]]; then
        if ! pkexec /usr/bin/x3d-toggle "$NEW_MODE" 2>/dev/null; then
            NOW=$(date +%s)
            if (( NOW - LAST_ERROR_TIME > ERROR_COOLDOWN )); then
                if command -v notify-send &> /dev/null; then
                    notify-send -a "X3D Toggle" "X3D Control Error" "<font color='#ff6d00'>Critical: Failed to switch to $NEW_MODE.</font>" 2>/dev/null
                fi
                LAST_ERROR_TIME=$NOW
            fi
        fi
    fi
    sleep "$POLL_INTERVAL"
done
