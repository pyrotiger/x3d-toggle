# EditorConfig for x3d-toggle project
# https://editorconfig.org

root = true

# All files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Shell scripts
[*.{sh,bash}]
indent_style = space
indent_size = 4

# YAML files (systemd, config)
[*.{yaml,yml,service}]
indent_style = space
indent_size = 2

# Markdown
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# Configuration files
[*.{conf,conf.d}]
indent_style = space
indent_size = 4

# PKGBUILD
[PKGBUILD]
indent_style = space
indent_size = 4

# XML/PolicyKit
[*.{xml,policy}]
indent_style = space
indent_size = 2

# Desktop files
[*.desktop]
indent_style = space
indent_size = 0
