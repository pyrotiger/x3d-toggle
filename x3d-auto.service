[Unit]
Description=AMD X3D VCACHE Technology Autonomous Daemon Scheduler
ConditionPathExists=/usr/bin/x3d-daemon
ConditionPathExists=/sys/devices/platform/AMDI8280:00/amd_x3d_mode
After=graphical-session.target

[Service]
ExecStart=/usr/bin/x3d-daemon
Restart=always
RestartSec=3

[Install]
WantedBy=graphical-session.target
