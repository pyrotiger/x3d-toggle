[Unit]
Description=AMD 3D V-Cache Performance Optimizer Autonomous Daemon Scheduler
ConditionPathExists=/usr/bin/x3d-daemon
After=graphical-session.target

[Service]
ExecStart=/usr/bin/x3d-daemon
Restart=always
RestartSec=3
# Hardening: reduce privilege surface for the user service
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ProtectHome=yes
ProtectKernelTunables=yes
ProtectControlGroups=yes
ProtectKernelModules=yes
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
PrivateDevices=yes
ReadOnlyPaths=/usr/bin /usr/lib /etc
ReadWritePaths=%t %h/.local/share/x3d-toggle

[Install]
WantedBy=graphical-session.target
