TARGET=$(find /sys/devices/platform -name amd_x3d_mode 2>/dev/null | head -n 1)

if [ -z "$TARGET" ] || [ ! -f "$TARGET" ]; then
    exit 1
fi

REQUESTED_MODE=$1

# Strict Input Validation (Sanitization)
case "$REQUESTED_MODE" in
    "cache"|"frequency"|"auto")
        if ! printf "%s" "$REQUESTED_MODE" > "$TARGET"; then
            exit 1
        fi
        ;;
    *)
        exit 1
        ;;
esac